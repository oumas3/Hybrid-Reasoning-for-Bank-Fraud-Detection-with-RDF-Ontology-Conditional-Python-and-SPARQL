<owl:Class rdf:about="#CompteBancaire">
  <rdfs:subClassOf>
    <owl:Restriction>
      <owl:onProperty rdf:resource="#effectueTransaction"/>
      <owl:someValuesFrom rdf:resource="#Transaction"/>
    </owl:Restriction>
  </rdfs:subClassOf>
  <rdfs:subClassOf>
    <owl:Restriction>
      <owl:onProperty rdf:resource="#recoitTransaction"/>
      <owl:someValuesFrom rdf:resource="#Transaction"/>
    </owl:Restriction>
  </rdfs:subClassOf>
  <rdfs:subClassOf>
    <owl:Restriction>
      <owl:onProperty rdf:resource="#estPossedePar"/>
      <owl:onClass rdf:resource="#Personne"/>
      <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
    </owl:Restriction>
  </rdfs:subClassOf>
</owl:Class>

<owl:Class rdf:about="#Transaction"/>

<owl:Class rdf:about="#Personne">
  <rdfs:subClassOf>
    <owl:Restriction>
      <owl:onProperty rdf:resource="#possede"/>
      <owl:someValuesFrom rdf:resource="#CompteBancaire"/>
    </owl:Restriction>
  </rdfs:subClassOf>
</owl:Class>

<owl:Class rdf:about="#Emetteur">
