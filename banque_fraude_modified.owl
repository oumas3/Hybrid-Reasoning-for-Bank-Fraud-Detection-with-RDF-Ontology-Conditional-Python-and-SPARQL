<owl:Ontology rdf:about="http://www.semanticweb.org/ontologies/banque_fraude"/>

<owl:ObjectProperty rdf:about="#effectueTransaction">
  <owl:inverseOf rdf:resource="#estEffectueePar"/>
  <rdfs:domain rdf:resource="#CompteBancaire"/>
  <rdfs:range rdf:resource="#Transaction"/>
</owl:ObjectProperty>

